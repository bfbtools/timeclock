# Back Forty Builders Time Clock — environment variables
# Copy this file to `.env` for local dev (`netlify dev`). NEVER commit `.env`.
# In production these are set in the Netlify UI (Site settings → Environment variables).

# --- Google Sheets (service account) ---
# The FULL JSON key for the service account, as a single line.
# From the downloaded key file, paste its entire contents here (keep the quotes).
# The service-account email inside this JSON must be shared on the Sheet as Editor.
GOOGLE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}'

# The Google Sheet that is the datastore (already seeded with Subs/Workers/Projects).
SHEET_ID=1CAVJjOGH0zxfTaEnuUcP6HBhRrtld6UfMZzWZMbPJfc

# --- Email (Resend) ---
# API key from Resend; the backforty.builders domain must be verified there.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where invoices/notifications are sent from and copied to.
ACCOUNTING_EMAIL=accounting@backforty.builders
