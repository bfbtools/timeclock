# Back Forty Builders Time Clock — environment variables
# Copy this file to `.env` for local dev (`netlify dev`). NEVER commit `.env`.
# In production these are set in the Netlify UI (Site settings → Environment variables).

# --- Google Sheets (service account) ---
# The FULL JSON key for the service account, as a single line.
# From the downloaded key file, paste its entire contents here (keep the quotes).
# The service-account email inside this JSON must be shared on the Sheet as Editor.
GOOGLE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}'

# The Google Sheet that is the datastore (already seeded with Subs/Workers/Projects).
SHEET_ID=1CAVJjOGH0zxfTaEnuUcP6HBhRrtld6UfMZzWZMbPJfc

# --- Email (Resend) ---
# API key from Resend; the backforty.builders domain must be verified there.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where invoices/notifications are sent from and copied to.
ACCOUNTING_EMAIL=accounting@backforty.builders

# Public base URL of the app (used to build the QR-code links). Defaults to the
# production domain if unset; set it if you use a different domain.
SITE_URL=https://timeclock.backforty.builders

# --- Admin ---
# Private token protecting the invoice preview / manual-run endpoint
# (/api/invoice-preview). Use a long random string. Without it that endpoint
# returns 403. Only you use it; keep it secret.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Invoice test mode (safe to leave set) ---
# Set to a single email address to route TEST invoice sends to yourself. This
# ONLY affects the manual /api/invoice-preview endpoint (with &send=1): every
# invoice goes to this address with a [TEST] subject and nothing is logged.
# The scheduled Monday run (invoice-run.js) IGNORES this and always emails the
# real subs and logs normally — so you can safely leave this set for repeat
# testing without affecting production.
TEST_INVOICE_EMAIL=

# --- Drive (materials receipts, optional) ---
# Google Drive folder ID where receipt photos are uploaded (the folder must be
# shared with the service-account email as Editor, and the Drive API enabled).
# If unset, materials still save — just without a receipt link.
DRIVE_FOLDER_ID=
